# LLM Provider: "openai" or "anthropic"
LLM_PROVIDER=openai

# API Key (works for both providers)
API_KEY=your-api-key-here

# API Base URL (for third-party proxies)
# OpenAI-compatible: https://www.right.codes/codex/v1
# Anthropic-compatible: https://api.deepseek.com/anthropic
API_BASE_URL=https://www.right.codes/codex/v1

# Model ID
MODEL_ID=gpt-5.4-mini

# Trading Config
PAPER_TRADING=true
DEFAULT_EXCHANGE=gateio
INITIAL_BALANCE_USDT=10000
MAX_ORDER_SIZE_USDT=1000
