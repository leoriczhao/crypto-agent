# LLM Provider: "openai" or "anthropic"
LLM_PROVIDER=openai

# API Key (works for both providers)
API_KEY=your-api-key-here

# API Base URL (for third-party proxies)
# OpenAI-compatible: https://www.right.codes/codex/v1
# Anthropic-compatible: https://api.deepseek.com/anthropic
API_BASE_URL=https://www.right.codes/codex/v1

# Model
MODEL_ID=gpt-5.4
LLM_CONTEXT_WINDOW=500000

# --- LLM generation (OpenAI-compatible path uses all; Anthropic uses max_tokens/temp/top_p/top_k)
# Leave sampling vars empty to omit them (server default).
LLM_MAX_TOKENS=4096
# LLM_TEMPERATURE=0.7
# LLM_TOP_P=0.95
# LLM_FREQUENCY_PENALTY=0
# LLM_PRESENCE_PENALTY=0
# LLM_SEED=42
# LLM_STOP=END|</s>
# Gateway-specific JSON merged into OpenAI extra_body, e.g. reasoning controls:
# LLM_EXTRA_BODY_JSON={"reasoning_effort":"high"}

# Anthropic-only (ignored when LLM_PROVIDER=openai)
# ANTHROPIC_TOP_K=5

# Sub-agent (delegate) max output tokens
SUB_AGENT_MAX_TOKENS=2048

# Manual/auto context compaction summary call
COMPACT_SUMMARY_MAX_TOKENS=1024
# COMPACT_SUMMARY_MODEL_ID=gpt-5.4

# Context estimation: chars per token (rough), for AUTO_COMPACT threshold only
CONTEXT_CHARS_PER_TOKEN=4

# Micro-compact: shorten old tool results in-place each turn
MICRO_COMPACT_ENABLED=true
MICRO_COMPACT_KEEP_RECENT=3
MICRO_COMPACT_MIN_CONTENT_LEN=200

# Auto compact (off by default; threshold defaults to LLM_CONTEXT_WINDOW)
AUTO_COMPACT_ENABLED=false
# AUTO_COMPACT_TOKEN_THRESHOLD=500000

# Trading Config
PAPER_TRADING=true
DEFAULT_EXCHANGE=gateio
INITIAL_BALANCE_USDT=10000
MAX_ORDER_SIZE_USDT=1000

# Exchange API Keys (required for PAPER_TRADING=false)
# Get from: Gate.io → API Management → Create API Key
EXCHANGE_API_KEY=
EXCHANGE_SECRET=
EXCHANGE_PASSWORD=

# Extra Exchanges (JSON, optional)
# EXTRA_EXCHANGES={"okx":{"api_key":"...","secret":"..."},"bybit":{"api_key":"...","secret":"..."}}

# Trading Personality: conservative, balanced, aggressive
TRADING_SOUL=balanced

# Daemon Mode
HEARTBEAT_INTERVAL=60
MEMORY_DB_PATH=crypto_agent.db

# Telegram Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
